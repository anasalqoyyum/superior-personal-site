---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Not Found">
  <div class="my-auto flex flex-col items-start justify-center max-w-xl">
    <span
      class="font-mono text-xs uppercase tracking-[0.2em] mb-6"
      style="color: var(--text-muted)"
    >
      Error
    </span>
    <h1
      class="font-serif font-light italic leading-none mb-4"
      style="font-size: clamp(5rem, 20vw, 12rem); color: var(--text)"
    >
      418
    </h1>
    <h2
      class="font-serif font-medium text-2xl sm:text-3xl mb-4"
      style="color: var(--text)"
    >
      I'm a Teapot
    </h2>
    <p class="text-sm leading-relaxed mb-8" style="color: var(--text-muted)">
      Actually, the page hasn't been found —<br />but 404 is too boring.
    </p>
    <a
      href="/"
      class="font-mono text-xs uppercase tracking-[0.15em] px-5 py-3 transition-all duration-200 rounded-sm"
      style="color: var(--accent); border: 1px solid var(--accent)"
      onmouseover="this.style.backgroundColor='var(--accent)'; this.style.color='var(--bg)'"
      onmouseout="this.style.backgroundColor=''; this.style.color='var(--accent)'"
    >
      Return Home
    </a>
  </div>
</Layout>

---
import { getCollection } from 'astro:content'
import BlogItem from '../../components/BlogItem.astro'
import { SITE_TITLE } from '../../consts'
import Layout from '../../layouts/Layout.astro'

const posts = await getCollection('blog')
const nonHiddenPosts = posts
  .filter(post => !post.data.hidden)
  .filter(post => post.id.includes('en/'))
nonHiddenPosts.sort(
  (a, b) => Date.parse(b.data.publishedAt) - Date.parse(a.data.publishedAt)
)

// Group posts by year
const postsByYear = nonHiddenPosts.reduce(
  (acc, post) => {
    const year = new Date(post.data.publishedAt).getFullYear()
    if (!acc[year]) acc[year] = []
    acc[year].push(post)
    return acc
  },
  {} as Record<number, typeof nonHiddenPosts>
)
const years = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a)
---

<Layout title={SITE_TITLE}>
  <div>
    <header class="mb-12">
      <h1
        class="font-serif font-light italic"
        style="font-size: clamp(2.5rem, 8vw, 5rem); line-height: 1; color: var(--text)"
      >
        Writing
      </h1>
      <p class="mt-3 text-sm" style="color: var(--text-muted)">
        Thoughts on software, games, and everything in between.
      </p>
    </header>

    <div class="space-y-10">
      {
        years.map(year => (
          <section>
            <div class="mb-4 flex items-center gap-4">
              <span
                class="font-mono text-xs font-medium"
                style="color: var(--text-muted)"
              >
                {year}
              </span>
              <div
                class="h-px flex-1"
                style="background-color: var(--border)"
              />
            </div>
            <ul>
              {postsByYear[year].map(post => (
                <li>
                  <BlogItem url={`/blog/${post.id}`} {...post.data} />
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</Layout>

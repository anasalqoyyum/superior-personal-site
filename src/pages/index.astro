---
import { Image } from 'astro:assets'
import avatar from '../assets/images/avatar.png'
import photo from '../assets/images/photo.jpg'
import Layout from '../layouts/Layout.astro'

const title = 'Anas Alqoyyum — Software Engineer'
---

<Layout title={title}>
  <article class="my-auto">
    <div
      class="title flex cursor-default items-end justify-between gap-4 select-none"
    >
      <!-- Name — single line, large Playfair Display -->
      <h1
        class="font-serif leading-none font-bold tracking-tight"
        style="font-size: clamp(2.5rem, 9vw, 6.25rem); color: var(--text)"
      >
        Anas Alqoyyum
      </h1>

      <!-- Avatar — bottom-aligned with name baseline, flips on hover of .title -->
      <div
        class="relative mb-1 h-16 w-16 shrink-0 sm:h-20 sm:w-20"
        aria-hidden="true"
      >
        <div
          class="avatar absolute inset-0 overflow-hidden rounded-full"
          style="box-shadow: 0 0 0 1px var(--border)"
        >
          <Image
            src={avatar}
            width={80}
            height={80}
            loading="eager"
            alt="Anas Alqoyyum"
            class="h-full w-full object-cover"
          />
        </div>
        <div
          class="photo h-full w-full overflow-hidden rounded-full"
          style="box-shadow: 0 0 0 1px var(--border)"
        >
          <Image
            src={photo}
            width={80}
            height={80}
            loading="eager"
            alt="Anas Alqoyyum"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>

    <!-- Divider + tagline -->
    <div
      class="mt-8 flex flex-col gap-2 pt-5 sm:flex-row sm:items-center sm:justify-between"
      style="border-top: 1px solid var(--border)"
    >
      <p
        class="font-mono text-xs tracking-[0.2em] uppercase"
        style="color: var(--text-muted)"
      >
        Software Engineer
      </p>
      <p class="font-mono text-xs" style="color: var(--text-muted)">
        Jakarta, Indonesia
      </p>
    </div>
  </article>
</Layout>
